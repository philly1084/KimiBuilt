{
  "manifest_version": 3,
  "name": "LillyBuilt Agent SDK Controller",
  "version": "1.0.0",
  "description": "Control and monitor the OpenAI Agent SDK from your browser",
  "author": "LillyBuilt",
  
  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "background"
  ],
  
  "host_permissions": [
    "http://localhost:*/*",
    "https://localhost:*/*"
  ],
  
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "LillyBuilt Agent SDK"
  },
  
  "background": {
    "service_worker": "background/background.js",
    "type": "module"
  },
  
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/content.js"],
      "css": ["content/content.css"],
      "run_at": "document_end"
    }
  ],
  
  "options_page": "options/options.html",
  
  "devtools_page": "devtools/devtools.html",
  
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  
  "web_accessible_resources": [
    {
      "resources": ["shared/*", "icons/*"],
      "matches": ["<all_urls>"]
    }
  ],
  
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Ctrl+Shift+K",
        "mac": "Command+Shift+K"
      },
      "description": "Open Agent SDK popup"
    },
    "toggle-agent": {
      "suggested_key": {
        "default": "Ctrl+Shift+A",
        "mac": "Command+Shift+A"
      },
      "description": "Toggle Agent on current page"
    },
    "quick-task": {
      "suggested_key": {
        "default": "Ctrl+Shift+T",
        "mac": "Command+Shift+T"
      },
      "description": "Open quick task dialog"
    }
  }
}
