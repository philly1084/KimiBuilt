    "marked": "^12.0.0",
    "marked-terminal": "^7.0.0",
    "minimist": "^1.2.8",
    "openai": "^4.104.0",
    "ora": "^5.4.1",
    "strip-ansi": "^6.0.1"
  },
  "devDependencies": {
    "eslint": "^8.57.0",
