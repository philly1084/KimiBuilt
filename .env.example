# ===========================
# KimiBuilt - Environment Config
# ===========================

# OpenAI - Generation
# For local development:
OPENAI_API_KEY=sk-your-api-key-here
OPENAI_BASE_URL=https://api.openai.com/v1

# For k3s deployment with n8n-openai-cli-gateway:
# OPENAI_API_KEY=your-gateway-api-key
# OPENAI_BASE_URL=http://n8n-openai-cli-gateway.n8n-openai-gateway.svc.cluster.local/v1
OPENAI_MODEL=gpt-4o

# Ollama - Embeddings
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_EMBED_MODEL=nomic-embed-text:latest

# Qdrant - Vector Store
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=conversations

# Postgres - Artifact and session storage
# POSTGRES_URL=postgres://kimibuilt:password@postgres:5432/kimibuilt
# POSTGRES_HOST=postgres
# POSTGRES_PORT=5432
# POSTGRES_DB=kimibuilt
# POSTGRES_USER=kimibuilt
# POSTGRES_PASSWORD=change-me
# POSTGRES_SSL=false

# Artifact rendering
# In the container image this defaults to /usr/bin/chromium
# ARTIFACT_BROWSER_PATH=/usr/bin/chromium
# ARTIFACT_BROWSER_ARGS=--disable-software-rasterizer
# ARTIFACT_PDF_TIMEOUT_MS=15000

# Server
PORT=3000
NODE_ENV=development