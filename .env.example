# KimiBuilt Environment Variables

# OpenAI API Configuration
OPENAI_API_KEY=your_openai_api_key_here

# Optional: Custom OpenAI base URL (for proxies like LiteLLM)
# OPENAI_BASE_URL=http://localhost:8000/v1

# Unsplash API Configuration (for image search)
# Get your access key at: https://unsplash.com/developers
UNSPLASH_ACCESS_KEY=your_unsplash_access_key_here

# Server Configuration
PORT=3000
NODE_ENV=development

# Remote-build autonomy budget for Notes / SSH workflows
REMOTE_BUILD_MAX_AUTONOMOUS_ROUNDS=8
REMOTE_BUILD_MAX_AUTONOMOUS_TOOL_CALLS=24
REMOTE_BUILD_MAX_AUTONOMOUS_MS=120000

# Session Configuration
SESSION_SECRET=your_random_session_secret_here

# Database (if using persistent storage)
# DATABASE_URL=postgresql://user:pass@localhost:5432/kimibuilt
