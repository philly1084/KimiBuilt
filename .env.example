# KimiBuilt Environment Variables

# OpenAI API Configuration
OPENAI_API_KEY=your_openai_api_key_here

# Optional: Custom OpenAI base URL (for proxies like LiteLLM)
# OPENAI_BASE_URL=http://localhost:8000/v1

# Optional: Force which upstream API surface the SDK wrapper uses.
# auto = Responses for official OpenAI hosts, Chat Completions for custom hosts
# chat = always use Chat Completions upstream
# responses = always use Responses API upstream
# OPENAI_API_MODE=auto

# Unsplash API Configuration (for image search)
# Get your access key at: https://unsplash.com/developers
UNSPLASH_ACCESS_KEY=your_unsplash_access_key_here

# Server Configuration
PORT=3000
NODE_ENV=development

# Remote-build autonomy budget for Notes / SSH workflows
REMOTE_BUILD_MAX_AUTONOMOUS_ROUNDS=8
REMOTE_BUILD_MAX_AUTONOMOUS_TOOL_CALLS=24
REMOTE_BUILD_MAX_AUTONOMOUS_MS=120000

# Memory / research tuning
MEMORY_RECENT_MESSAGE_WINDOW=40
MEMORY_RECENT_TRANSCRIPT_LIMIT=20
MEMORY_RECENT_MESSAGE_CHAR_LIMIT=6000
MEMORY_RECALL_TOP_K=12
MEMORY_RESEARCH_RECALL_TOP_K=16
WEB_RESEARCH_SEARCH_LIMIT=16
WEB_RESEARCH_FOLLOWUP_PAGES=6
WEB_RESEARCH_SOURCE_EXCERPT_CHARS=2000
TOOL_RESULT_CHAR_LIMIT=18000

# Web tool tuning
WEB_SEARCH_DEFAULT_LIMIT=12
WEB_SEARCH_MAX_LIMIT=20
WEB_SCRAPE_CONTENT_CHAR_LIMIT=12000

# Session Configuration
SESSION_SECRET=your_random_session_secret_here

# Database (if using persistent storage)
# DATABASE_URL=postgresql://user:pass@localhost:5432/kimibuilt
