# KimiBuilt Environment Variables

# OpenAI API Configuration
OPENAI_API_KEY=your_openai_api_key_here

# Optional: Custom OpenAI base URL (for proxies like LiteLLM)
# OPENAI_BASE_URL=http://localhost:8000/v1
#
# n8n OpenAI CLI Gateway example:
# OPENAI_BASE_URL=http://localhost:8080/v1
# OPENAI_API_KEY=replace_with_N8N_API_KEY
# OPENAI_API_MODE=chat
# OPENAI_REASONING_EFFORT=medium
# OPENAI_REQUEST_TIMEOUT_MS=900000
# OPENAI_TOOL_REQUEST_TIMEOUT_MS=900000
# OPENAI_IMAGE_MODEL=gpt-image-2
# OPENAI_IMAGE_BATCH_CONCURRENCY=4
# OPENAI_IMAGE_ALLOW_OFFICIAL_FALLBACK=false

# Optional: Force which upstream API surface the SDK wrapper uses.
# auto = Responses for official OpenAI hosts, Chat Completions for custom hosts
# chat = always use Chat Completions upstream
# responses = always use Responses API upstream
# OPENAI_API_MODE=auto

# Optional frontend token for the standalone Node CLI.
# When backend auth is enabled, set this on both the backend and the CLI client.
# The CLI uses it for `/v1/*`, standard `/api/*`, and `/admin/provider-sessions/*`.
# KIMIBUILT_FRONTEND_API_KEY=replace_me

# Optional: Perplexity web search and research presets.
# `web-search` now supports raw search plus `fast-search`, `pro-search`, `deep-research`,
# and `advanced-deep-research` modes through the same API key.
# PERPLEXITY_API_KEY=your_perplexity_api_key_here
# PERPLEXITY_BASE_URL=https://api.perplexity.ai

# Unsplash API Configuration (for image search)
# Get your access key at: https://unsplash.com/developers
UNSPLASH_ACCESS_KEY=your_unsplash_access_key_here

# Server Configuration
PORT=3000
NODE_ENV=development

# Security and public access hardening
# Production defaults to requiring auth. Development defaults to open mode.
# KIMIBUILT_AUTH_REQUIRED=true
# KIMIBUILT_AUTH_USERNAME=admin
# KIMIBUILT_AUTH_PASSWORD=replace-with-a-strong-password
# KIMIBUILT_JWT_SECRET=replace-with-a-long-random-secret
# Comma-separated browser origins allowed to call the API. Same-origin requests do not need an Origin header.
# KIMIBUILT_ALLOWED_ORIGINS=http://localhost:3000,https://kimibuilt.example.com
# Query-string API tokens are disabled by default in production; WebSocket auth tokens still work.
# KIMIBUILT_ALLOW_QUERY_TOKENS=false
# KIMIBUILT_RATE_LIMIT_WINDOW_MS=60000
# KIMIBUILT_RATE_LIMIT_MAX=120
# KIMIBUILT_LOGIN_RATE_LIMIT_MAX=10
# KIMIBUILT_TOOL_RATE_LIMIT_MAX=30

# Text-to-speech
# Kokoro is the default local provider. Piper remains available as a rollout fallback.
# TTS_PROVIDER=kokoro
# TTS_FALLBACK_PROVIDER=piper
# TTS_FALLBACK_ENABLED=true
# KOKORO_TTS_ENABLED=true
# KOKORO_TTS_MODEL_ID=onnx-community/Kokoro-82M-v1.0-ONNX
# KOKORO_TTS_DEVICE=cpu
# KOKORO_TTS_DTYPE=q8
# KOKORO_TTS_VOICES_PATH=data\kokoro\voices\manifest.json
# KOKORO_TTS_DEFAULT_VOICE_ID=af_heart
# KOKORO_TTS_TIMEOUT_MS=90000
# KOKORO_TTS_PODCAST_TIMEOUT_MS=240000
# KOKORO_TTS_PODCAST_CHUNK_CHARS=900

# Piper text-to-speech fallback
# Example Windows paths:
# PIPER_TTS_BINARY_PATH=C:\tools\piper\piper.exe
# PIPER_TTS_MODEL_PATH=C:\voices\en_US-amy-medium.onnx
# PIPER_TTS_CONFIG_PATH=C:\voices\en_US-amy-medium.onnx.json
# PIPER_TTS_VOICES_PATH=data\piper\voices\manifest.json
# PIPER_TTS_DEFAULT_VOICE_ID=amy-medium
# PIPER_TTS_VOICE_LABEL=Female natural
# PIPER_TTS_SPEAKER_ID=0
# PIPER_TTS_ENABLED=true
# PIPER_TTS_TIMEOUT_MS=45000
# PIPER_TTS_PODCAST_TIMEOUT_MS=210000
# PIPER_TTS_PODCAST_CHUNK_CHARS=760
# PIPER_TTS_NOISE_SCALE=0.38
# PIPER_TTS_NOISE_W=0.68

# Optional ffmpeg-backed podcast post-processing
# Podcast WAV generation defaults to voice-only native packaging. ffmpeg is used
# only when MP3 export or explicit post-processing/mixing is requested.
# FFMPEG_BINARY_PATH=C:\ffmpeg\bin\ffmpeg.exe
# AUDIO_PROCESSING_ENABLED=true
# AUDIO_PROCESSING_TIMEOUT_MS=90000
# PODCAST_TOOL_TIMEOUT_MS=2700000
# PODCAST_VIDEO_SEGMENT_TIMEOUT_MS=240000
# PODCAST_VIDEO_MUX_TIMEOUT_MS=900000
# PODCAST_VIDEO_MAX_FFMPEG_TIMEOUT_MS=1800000
# PODCAST_VIDEO_RENDER_MODE=waveform-card
# PODCAST_VIDEO_DEFAULT_SCENE_COUNT=14
# PODCAST_VIDEO_AUDIO_REPAIR_ENABLED=false
# PODCAST_VIDEO_VISUAL_EFFECTS_ENABLED=true
# PODCAST_VIDEO_X264_PRESET=veryfast
# PODCAST_VIDEO_X264_CRF=23
# PODCAST_MP3_BITRATE_KBPS=192
# PODCAST_MASTERING_ENABLED=true
# PODCAST_MASTERING_LOUDNESS_LUFS=-16
# PODCAST_MASTERING_TRUE_PEAK_DB=-1.5
# PODCAST_INTRO_PATH=data\podcast\intro.wav
# PODCAST_OUTRO_PATH=data\podcast\outro.wav
# PODCAST_MUSIC_BED_PATH=data\podcast\bed.wav
# PODCAST_SPEECH_VOLUME=1.0
# PODCAST_MUSIC_VOLUME=0.07
# PODCAST_INTRO_VOLUME=1.0
# PODCAST_OUTRO_VOLUME=1.0

# Remote-build autonomy budget for Notes / SSH workflows
REMOTE_BUILD_MAX_AUTONOMOUS_ROUNDS=8
REMOTE_BUILD_MAX_AUTONOMOUS_TOOL_CALLS=24
REMOTE_BUILD_MAX_AUTONOMOUS_MS=120000

# Memory / research tuning
MEMORY_RECENT_MESSAGE_WINDOW=40
MEMORY_RECENT_TRANSCRIPT_LIMIT=20
MEMORY_RECENT_MESSAGE_CHAR_LIMIT=6000
MEMORY_RECALL_TOP_K=12
MEMORY_RESEARCH_RECALL_TOP_K=16
WEB_RESEARCH_SEARCH_LIMIT=16
WEB_RESEARCH_FOLLOWUP_PAGES=6
WEB_RESEARCH_SOURCE_EXCERPT_CHARS=2000
TOOL_RESULT_CHAR_LIMIT=18000

# Web tool tuning
WEB_SEARCH_DEFAULT_LIMIT=12
WEB_SEARCH_MAX_LIMIT=20
WEB_SCRAPE_CONTENT_CHAR_LIMIT=12000
WEB_SCRAPE_RESPECT_ROBOTS_TXT=true
WEB_SCRAPE_ROBOTS_TIMEOUT_MS=8000

# Optional browser runtime for rendered scraping
# Install `playwright` or `playwright-core` in the backend and point this at Chrome/Chromium if needed.
# PLAYWRIGHT_EXECUTABLE_PATH=/usr/bin/chromium
# ARTIFACT_BROWSER_PATH=/usr/bin/chromium
# ARTIFACT_BROWSER_ARGS=--disable-web-security
# OLLAMA_EMBED_TIMEOUT_MS=30000
# ARTIFACT_VECTORIZE_MAX_CHUNKS=24

# Direct backend provider-session CLIs (`/providers`, `/attach codex-cli`, `/attach gemini-cli`, `/attach kimi-cli`)
# Command overrides are optional; defaults are `codex`, `gemini`, and `kimi` on PATH.
# CODEX_CLI_COMMAND=codex
# CODEX_CLI_ARGS=
# CODEX_OPENAI_API_KEY=sk-your-openai-key
# CODEX_OPENAI_BASE_URL=https://api.openai.com/v1
#
# GEMINI_CLI_COMMAND=gemini
# GEMINI_CLI_ARGS=
# GEMINI_API_KEY=your_gemini_api_key
# GOOGLE_API_KEY=your_gemini_api_key
#
# KIMI_CLI_COMMAND=kimi
# KIMI_CLI_ARGS=
# MOONSHOT_API_KEY=your_moonshot_api_key
# MOONSHOT_BASE_URL=https://api.moonshot.ai/v1

# Server-side OpenAI Agents SDK remote CLI MCP integration.
# This lets the backend attach the gateway `/mcp` path as a Streamable HTTP MCP server.
# Keep the bearer token server-side only; never expose it in browser JavaScript.
# GATEWAY_URL=http://localhost:8080
# REMOTE_CLI_MCP_URL=http://localhost:8080/mcp
# REMOTE_CLI_MCP_BEARER_TOKEN=replace_with_N8N_OR_ADMIN_KEY
# N8N_API_KEY=replace_with_N8N_OR_ADMIN_KEY
# Gateway should include the admin scope when remote-cli-agent is allowed to perform scoped real deployments.
# REMOTE_CLI_TOOL_AUTH_SCOPES=n8n,frontend,admin
# REMOTE_CLI_DEFAULT_TARGET_ID=prod
# REMOTE_CLI_DEFAULT_CWD=/srv/apps/my-app
# REMOTE_CLI_AGENT_MODEL=gpt-4o
# REMOTE_CLI_AGENT_OPENAI_API_MODE=chat
# REMOTE_CLI_AGENT_MAX_TURNS=20

# Symphony orchestration can dispatch GitLab issues through the cluster remote-cli-agent.
# SYMPHONY_AGENT_RUNNER=remote-cli-agent
# GITLAB_ENABLED=true
# GITLAB_BASE_URL=https://gitlab.demoserver2.buzz
# GITLAB_GROUP=agent-apps
# GITLAB_TOKEN=glpat_your_gitlab_token_here

# API base URL used by remote OpenCode workers to call back into this KimiBuilt instance.
# This must be a non-local URL when using `target: "remote-default"`.
# API_BASE_URL=https://kimibuilt.example.com

# Optional Docker runtime for `docker-exec` and `code-sandbox`
# Host-run backend usually only needs Docker Desktop running.
# Containerized backends can point at a socket proxy or remote daemon.
# DOCKER_HOST=tcp://docker-proxy:2375
# DOCKER_TLS_VERIFY=1
# DOCKER_CERT_PATH=/path/to/docker-certs

# Session Configuration
SESSION_SECRET=your_random_session_secret_here

# Persistent state and managed local repository workspace
# KIMIBUILT_DATA_DIR=/home/kimibuilt/.kimibuilt
# KIMIBUILT_PUBLIC_SOURCE_INDEX_PATH=/home/kimibuilt/.kimibuilt/public-source-index/catalog.json
# DEFAULT_GIT_REPOSITORY_PATH=/home/kimibuilt/.kimibuilt/workspaces/kimibuilt
# KIMIBUILT_DEPLOY_REPO_URL=https://github.com/philly1084/KimiBuilt.git
# KIMIBUILT_DEPLOY_BRANCH=master

# Local git author identity for agent commits
# KIMIBUILT_GIT_COMMIT_NAME=KimiBuilt Agent
# KIMIBUILT_GIT_COMMIT_EMAIL=kimibuilt-agent@local.invalid

# GitHub token used for managed git clone/fetch/push flows
# GITHUB_TOKEN=ghp_your_github_token_here
# GH_TOKEN=ghp_your_github_token_here

# Database (recommended for persistent OpenCode runs)
# DATABASE_URL=postgresql://kimibuilt:password@localhost:5432/kimibuilt
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5432
# POSTGRES_DB=kimibuilt
# POSTGRES_USER=kimibuilt
# POSTGRES_PASSWORD=change_me

# Remote OpenCode target workspace and optional auto-install
# OPENCODE_REMOTE_DEFAULT_WORKSPACE=/opt/kimibuilt
# OPENCODE_REMOTE_AUTO_INSTALL=true

# Remote GitOps deploy defaults
# KIMIBUILT_DEPLOY_TARGET_DIR=/opt/kimibuilt
# KIMIBUILT_DEPLOY_MANIFESTS_PATH=k8s
# KIMIBUILT_DEPLOY_NAMESPACE=kimibuilt
# KIMIBUILT_DEPLOY_DEPLOYMENT=backend
# KIMIBUILT_DEPLOY_CONTAINER=backend
# KIMIBUILT_DEPLOY_PUBLIC_DOMAIN=demoserver2.buzz
# KIMIBUILT_DEPLOY_INGRESS_CLASS=traefik
# KIMIBUILT_DEPLOY_TLS_CLUSTER_ISSUER=letsencrypt-prod
# KIMIBUILT_INGRESS_BASE_DOMAIN=demoserver2.buzz
# KIMIBUILT_ACME_EMAIL=philly1084@gmail.com
